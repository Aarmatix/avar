{
  "name": "@avar-standard/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for the AVAR reference verifier (bin/avar.ts, distributed via GitHub Releases + Homebrew) and the @avar-standard/* npm packages under packages/. Not published.",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present && node --test --experimental-strip-types packages/core/test/*.test.ts",
    "lint:vocab": "node ci/check-avar-vocabulary.mjs",
    "lint:publish-names": "node scripts/check-publish-names.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  },
  "homepage": "https://github.com/Aarmatix/avar"
}
